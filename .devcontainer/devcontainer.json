{
  "name": "geoflood-agent",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",
  "onCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [8000, 7860, 8501],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "eamodio.gitlens"
      ]
    }
  },
  "remoteEnv": {
    "PYTHONPATH": "/workspaces/geoflood-agent"
  }
}
